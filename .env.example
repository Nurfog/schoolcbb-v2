# ─── Base de datos ────────────────────────────────────────────
# Postgres: usuario:contraseña@host:puerto/base_datos
DATABASE_URL=postgres://usuario_ejemplo:contraseña_ejemplo@localhost:5432/mi_colegio

# ─── JWT (usado por identity, sis, academic, attendance) ────
# Generar con: openssl rand -hex 32
JWT_SECRET=mi-secreto-jwt-cambio-en-produccion

# ─── Gateway ─────────────────────────────────────────────────
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=3000
FRONTEND_URL=http://localhost:8080
IDENTITY_URL=http://identity.local:3001
SIS_URL=http://sis.local:3002
ACADEMIC_URL=http://academic.local:3003
ATTENDANCE_URL=http://attendance.local:3004
NOTIFICATIONS_URL=http://notifications.local:3005

# ─── Identity Service ────────────────────────────────────────
IDENTITY_HOST=0.0.0.0
IDENTITY_PORT=3001

# ─── SIS Service ─────────────────────────────────────────────
SIS_HOST=0.0.0.0
SIS_PORT=3002

# ─── Academic Service ────────────────────────────────────────
ACADEMIC_HOST=0.0.0.0
ACADEMIC_PORT=3003

# ─── Attendance Service ──────────────────────────────────────
ATTENDANCE_HOST=0.0.0.0
ATTENDANCE_PORT=3004

# ─── Notifications Service ───────────────────────────────────
NOTIFICATIONS_HOST=0.0.0.0
NOTIFICATIONS_PORT=3005

# ─── Logging ─────────────────────────────────────────────────
# Opciones: info, debug, trace, warn, error
# Formato: nivel,modulo= nivel
RUST_LOG=info,schoolcbb=debug
